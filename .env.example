# Copy to .env.local and fill in values from the DEDICATED Wedding Gully
# accounts — never from personal Supabase/Vercel accounts.

# --- Vercel ---
# Generate at: vercel.com (dedicated account) -> Settings -> Tokens
# Used via `vercel --token $VERCEL_TOKEN ...` so the CLI never needs a manual
# `vercel login`/`vercel logout` switch between this project and others.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Supabase ---
# Generate at: supabase.com (dedicated account) -> Account -> Access Tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_ANON_KEY=
